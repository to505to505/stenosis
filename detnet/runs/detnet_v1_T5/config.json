{
  "data_root": "data/dataset2_split",
  "output_dir": "detnet/runs",
  "run_name": "detnet_v1_T5",
  "img_size": 512,
  "T": 5,
  "pixel_mean": [
    0.485,
    0.456,
    0.406
  ],
  "pixel_std": [
    0.229,
    0.224,
    0.225
  ],
  "pretrained_coco": true,
  "rpn_pre_nms_top_n_train": 2000,
  "rpn_post_nms_top_n_train": 1000,
  "rpn_pre_nms_top_n_test": 1000,
  "rpn_post_nms_top_n_test": 400,
  "num_classes": 1,
  "backbone_out_channels": 256,
  "roi_size": 7,
  "sff_token_dim": 512,
  "sff_heads": 8,
  "sff_dropout": 0.0,
  "sff_use_residual_concat": true,
  "box_batch_size_per_image": 128,
  "box_positive_fraction": 0.25,
  "box_fg_iou_thresh": 0.5,
  "box_bg_iou_thresh": 0.5,
  "box_score_thresh": 0.05,
  "box_nms_thresh": 0.5,
  "box_detections_per_img": 100,
  "supervise_all_frames": true,
  "sca_enabled_eval": true,
  "sca_t_iou": 0.2,
  "sca_t_frame": 3,
  "sca_t_distance": 50.0,
  "sca_t_sim": 0.5,
  "sca_interpolate_missing": true,
  "epochs": 60,
  "batch_size": 2,
  "num_workers": 4,
  "lr": 0.02,
  "lr_backbone_mult": 0.1,
  "momentum": 0.9,
  "weight_decay": 0.0001,
  "grad_accum_steps": 8,
  "warmup_iters": 500,
  "lr_schedule": "cosine",
  "lr_step_milestones": [
    40,
    50
  ],
  "lr_gamma": 0.1,
  "grad_clip_max_norm": 10.0,
  "ema_enabled": true,
  "ema_decay": 0.999,
  "selection_smooth_k": 3,
  "selection_weights": [
    0.5,
    0.3,
    0.2
  ],
  "early_stop_enabled": true,
  "early_stop_patience": 6,
  "early_stop_min_delta": 0.0,
  "wandb_project": "detnet",
  "wandb_enabled": true,
  "log_interval": 50,
  "eval_interval": 2,
  "seed": 42,
  "amp": true
}